{
  "info": {
    "name": "Mini-CRM API",
    "description": "Postman collection for FNXPERTS Mini-CRM Laravel assessment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Change this to your server URL"
    }
  ],
  "item": [
    {
      "name": "Companies",
      "item": [
        {
          "name": "Get All Companies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/companies",
              "host": ["{{base_url}}"],
              "path": ["api", "companies"]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get Single Company with Employees",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/companies/1",
              "host": ["{{base_url}}"],
              "path": ["api", "companies", "1"]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          },
          "response": [
            {
              "name": "Success Response Example",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"id\": 1,\n    \"name\": \"Acme Corporation\",\n    \"email\": \"contact@acme.com\",\n    \"website\": \"https://acme.com\",\n    \"logo\": \"http://localhost:8000/storage/logos/example.png\",\n    \"employee_count\": 2,\n    \"employees\": [\n      {\n        \"id\": 1,\n        \"first_name\": \"John\",\n        \"last_name\": \"Doe\",\n        \"full_name\": \"John Doe\",\n        \"email\": \"john@acme.com\",\n        \"phone\": \"0123456789\",\n        \"company_id\": 1\n      }\n    ],\n    \"created_at\": \"2024-01-01T00:00:00.000000Z\",\n    \"updated_at\": \"2024-01-01T00:00:00.000000Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Non-existent Company (404 test)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/companies/9999",
              "host": ["{{base_url}}"],
              "path": ["api", "companies", "9999"]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    }
  ]
}
